# AWS Cognito
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Social Auth (configure in AWS Cognito Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=your-facebook-app-id

# OAuth Domain (set in Cognito > App Integration > Domain)
VITE_OAUTH_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_SIGN_IN=http://localhost:3000/
VITE_REDIRECT_SIGN_OUT=http://localhost:3000/login

# Plaid (server-side only — set these in Netlify environment variables, NOT in .env)
# Get keys at: https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox
# PLAID_ENV=development   # for real bank connections (limited accounts)
# PLAID_ENV=production    # for full production

# Optional: OAuth redirect (required for certain banks like Chase)
# PLAID_REDIRECT_URI=https://your-app.netlify.app/oauth-return
