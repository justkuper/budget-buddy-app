# AWS Amplify API Gateway URL — set this in Amplify environment variables
# This is the base URL of your deployed Lambda functions via API Gateway
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod
# Leave blank for local dev (Vite proxy handles it)
VITE_API_URL=

# AWS Cognito
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth — REQUIRED for Google Sign-In to work
# Setup: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized JS origins: https://budgetbuddy101.netlify.app  (and http://localhost:3000 for local dev)
# Authorized redirect URIs: https://budgetbuddy101.netlify.app
# Add this to Netlify: Site settings → Environment variables
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com

# Facebook OAuth — REQUIRED for Facebook Sign-In to work
# Setup: https://developers.facebook.com → My Apps → Create App → Facebook Login
# In Facebook Login settings, add to Valid OAuth Redirect URIs:
#   https://budgetbuddy101.netlify.app  AND  http://localhost:3000
# Add this to Netlify: Site settings → Environment variables
VITE_FACEBOOK_APP_ID=your-facebook-app-id

# OAuth Domain (set in Cognito > App Integration > Domain)
VITE_OAUTH_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_SIGN_IN=http://localhost:3000/
VITE_REDIRECT_SIGN_OUT=http://localhost:3000/login

# 2FA — Email (Resend) — https://resend.com (free tier: 3,000 emails/month)
# Set in Netlify environment variables (server-side only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 2FA — SMS (Twilio) — https://twilio.com
# Set in Netlify environment variables (server-side only)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# 2FA signing secret — any long random string, keep it secret
TWO_FA_SECRET=change-this-to-a-long-random-string

# Plaid (server-side only — set these in Netlify environment variables, NOT in .env)
# Get keys at: https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox
# PLAID_ENV=development   # for real bank connections (limited accounts)
# PLAID_ENV=production    # for full production

# Optional: OAuth redirect (required for certain banks like Chase)
# PLAID_REDIRECT_URI=https://your-app.netlify.app/oauth-return
