VITE_GOOGLE_CLIENT_ID=382797820688-jcqauk80m5882gcb3n444ra22u9pm9k6.apps.googleusercontent.com

# ─── Backend (Cognito) ────────────────────────────────────────────────────────
# Dev: Vite proxies /api → :3001 automatically — no need to set VITE_API_URL locally.
# Netlify: /api/* is rewritten to the serverless function — no need to set it either.
# Only set this if you're calling a deployed backend from a non-Netlify host:
# VITE_API_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/prod

# Cognito — used only if you switch to direct Amplify SDK calls later
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=
VITE_USER_POOL_CLIENT_ID=
